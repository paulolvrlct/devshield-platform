# Database
DB_HOST=postgres
DB_PORT=5432
DB_NAME=devshield
DB_USER=devshield
DB_PASSWORD=

# JWT
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=contact@devshield.fr

# App
NODE_ENV=development
API_PORT=3000
FRONTEND_URL=http://localhost
CORS_ORIGINS=http://localhost

# GeoIP (honeypot)
GEOIP_DB_PATH=/data/GeoLite2-City.mmdb

# Scanner
SCAN_RATE_LIMIT=10
SCAN_TIMEOUT_MS=30000
