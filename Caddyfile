# Caddyfile — DevShield Platform
# All subdomains with security headers

(security_headers) {
	header {
		Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		X-XSS-Protection "1; mode=block"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=()"
		-Server
		-X-Powered-By
	}
}

(common_proxy) {
	encode gzip

	handle /api/* {
		reverse_proxy api:3000
	}

	handle {
		reverse_proxy frontend:5173
	}
}

# VPN-only proxy : blocks any IP outside the WireGuard subnet.
# The block lives in a handle{} because handle blocks are evaluated
# in source order (first match wins), unlike top-level respond which
# Caddy runs AFTER reverse_proxy regardless of file order.
(common_proxy_vpn) {
	encode gzip

	@blocked not remote_ip 10.0.0.0/24
	handle @blocked {
		respond "Acces reserve au reseau interne (VPN)" 403
	}

	handle /api/* {
		reverse_proxy api:3000
	}

	handle {
		reverse_proxy frontend:5173
	}
}

# Shared CSP (Google Fonts external)
(csp_base) {
	header Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' ; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data:; font-src 'self' https://fonts.gstatic.com; connect-src 'self' wss:; frame-ancestors 'none'; base-uri 'self'; form-action 'self'"
}

# Main client dashboard (VPN only)
clients.devshield.fr {
	import security_headers
	import csp_base
	import common_proxy_vpn
}

# Invoices (VPN only)
factures.devshield.fr {
	import security_headers
	import csp_base
	import common_proxy_vpn
}

# OWASP Scanner (public)
audit.devshield.fr {
	import security_headers
	import csp_base

	# Redirect root to /scan for public access
	redir / /scan 302

	import common_proxy
}

# Onboarding form (public)
onboard.devshield.fr {
	import security_headers
	import csp_base

	# Redirect root to /onboarding for public access
	redir / /onboarding 302

	import common_proxy
}

# Honeypot dashboard (VPN only, also needs OpenStreetMap tiles)
honeypot.devshield.fr {
	import security_headers
	header Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' ; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data: https://*.tile.openstreetmap.org; font-src 'self' https://fonts.gstatic.com; connect-src 'self' wss:; frame-ancestors 'none'; base-uri 'self'; form-action 'self'"

	import common_proxy_vpn
}

# Uptime Kuma monitoring (VPN only)
status.devshield.fr {
	import security_headers

	@blocked not remote_ip 10.0.0.0/24
	handle @blocked {
		respond "Acces reserve au reseau interne (VPN)" 403
	}

	handle {
		reverse_proxy uptime-kuma:3001
	}
}
